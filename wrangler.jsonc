{
  "name": "seat-manager",
  "main": "src/worker.ts",
  "compatibility_date": "2026-04-10",
  "assets": {
    "directory": "dist",
    "not_found_handling": "single-page-application"
  },
  "triggers": {
    "crons": ["0 15 * * *", "*/10 * * * *"]
  },
  "vars": {
    "SUPABASE_URL": "https://xyhkjhcxdorcfuimraya.supabase.co",
    "OFFICE_IP": "REDACTED"
  },
  "observability": {
    "enabled": true,
    "logs": {
      "enabled": true,
      "invocation_logs": true
    }
  }
}
